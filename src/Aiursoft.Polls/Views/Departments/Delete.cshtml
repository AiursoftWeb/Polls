@model Aiursoft.Polls.Models.DepartmentsViewModels.DeleteViewModel

<h1 class="h3 mb-3">@Localizer["Delete Department"]</h1>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">@Localizer["Warning!"]</h5>
            </div>
            <div class="card-body">
                <p>@Localizer["Are you sure you want to delete the department "] <strong>@Model.Department.Name</strong>?</p>
                <form asp-action="Delete">
                    <input type="hidden" name="Id" value="@Model.Department.Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="align-middle me-2" data-lucide="trash"></i> @Localizer["Delete"]
                    </button>
                    <a asp-action="Index" class="btn btn-light">@Localizer["Cancel"]</a>
                </form>
            </div>
        </div>
    </div>
</div>
